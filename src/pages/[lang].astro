  { name: 'Green Bowl', price: '€11.90', tags: ['greens', 'salmon'], text: 'Mixed greens, marinated salmon, avocado, cherry tomato, cucumber, carrot, radish, red cabbage, spring onion, lemon, cream cheese, sesame seeds, poke mayo.' },
