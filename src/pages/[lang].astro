const schema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Bowl Bar Bled',
  servesCuisine: ['Poke', 'Bowls'],
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Ljubljanska cesta 4',
    postalCode: '4260',
    addressLocality: 'Bled',
    addressCountry: 'SI'
  },
  openingHours: 'Mo-Su 12:00-20:00',
  hasMenu: `${site}/${lang}/#menu`
};
---
<Base title={t.title} description={t.desc} lang={lang} canonical={`${site}/${lang}/`}>
  <Fragment slot="head">
    {['sl','en','de','it'].map((l) => <link rel="alternate" hreflang={l} href={`${site}/${l}/`} />)}
    <link rel="alternate" hreflang="x-default" href={`${site}/en/`} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <header class="topbar">
    <nav class="shell nav" aria-label="Main">
      <a class="logo" href={`/${lang}/`} aria-label="Bowl Bar Bled">
        <img src="/Bowl_bar_logo.png" alt="Bowl Bar" width="2878" height="2610" />
      </a>
      <div class="langs" aria-label="Languages">
        {['sl','en','de','it'].map((l) => <a href={`/${l}/`} aria-current={l === lang ? 'true' : 'false'}>{l.toUpperCase()}</a>)}
      </div>
    </nav>
  </header>

  <main>
    <section class="hero shell">

      <div class="fast" aria-label="Important information">
        <div class="fact"><b>{t.hours}</b><span>{t.open}</span></div>
        <div class="fact"><b>{t.address}</b><span>{t.center}</span></div>
      </div>

    </section>

    <section class="section shell menu-board" id="menu">
      <!-- <h2>{t.bowlsTitle}</h2> -->
      <div class="bowls">
        {bowls.map((b) => (
          <article class="bowl">
            <div class="bowl-head"><h3>{b.name}</h3><div class="price">{b.price}</div></div>
            <p>{b.text}</p>
            <div class="tags">{b.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
          </article>
        ))}
      </div>
    </section>


  </main>

  <footer class="shell footer">© {new Date().getFullYear()} Bowl Bar Bled</footer>

</Base>
